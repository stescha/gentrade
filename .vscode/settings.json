
{
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "python.analysis.typeCheckingMode": "off",

  // Explicitly pin the interpreter so VS Code never delegates to the Poetry env
  // manager for process spawning (avoids "Code: null, Signal: null" crash in
  // test-by-project discovery introduced in ms-python 2026.x).
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  "python.testing.pytestArgs": [
      "-l",          // Show local variables in tracebacks
      "--tb=short",   // Terse traceback style
      "-c",
      "pyproject.toml",
      "tests/"
  ],
  "python.testing.pytestEnabled": true,
        
// Run pytest from the package folder so --import-mode=importlib works with src layout
  "python.testing.cwd": "${workspaceFolder}",

  // Use a non-existent env file to prevent accidentally loading environment variables from .env
  "python.envFile": "${workspaceFolder}/.env.dontexist",

  // --- Configure Mypy extension (dmypy) ---
  "mypy.runUsingActiveInterpreter": true,
  "mypy.dmypyExecutable": "${workspaceFolder}/.venv/bin/dmypy",
  
  // Specify mypy config file relative to the workspace folder (don't use ${workspaceFolder} here)
  "mypy.configFile": "pyproject.toml",
  "python-envs.pythonProjects": [
    {
      "path": ".",
      "envManager": "ms-python.python:poetry",
      "packageManager": "ms-python.python:poetry"
    }
  ],

}

